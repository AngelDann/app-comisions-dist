# Copia este archivo a .env en la RAÍZ del repo (misma carpeta que manage.py y docker-compose.yml).
# Django carga ese archivo al arrancar (python-dotenv). Docker Compose también inyecta .env en web y celery_worker.

# --- Django ---
# Clave secreta obligatoria en producción (firma de sesiones, CSRF, etc.).
DJANGO_SECRET_KEY=change-me-in-production

# 1 = modo desarrollo (más logs, trazas de error). En producción usar 0.
DJANGO_DEBUG=1

# Hosts permitidos, separados por coma. Con Docker incluye el nombre del servicio (p. ej. web).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# --- Base de datos ---
# Postgres (recomendado). Ejemplo para docker-compose: host db, usuario wh, BD wh_tourn.
DATABASE_URL=postgres://wh:wh@db:5432/wh_tourn

# --- Redis ---
# DB 0: broker y backend de Celery por defecto.
REDIS_URL=redis://redis:6379/0

# --- Opcionales ---
# Registro público de compañías: true / false
# ALLOW_COMPANY_REGISTRATION=true

# Ejecutar tareas Celery en el mismo proceso (útil en tests); en producción dejar 0.
# CELERY_TASK_ALWAYS_EAGER=0
